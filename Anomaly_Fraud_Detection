            "New best score: 0.0376 (Iter 1)\n",
            "New best score: 0.0654 (Iter 5)\n",
            "New best score: 0.0654 (Iter 12)\n",
            "New best score: 0.0709 (Iter 26)\n",
            "New best score: 0.0709 (Iter 45)\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "bcf0deb2",
        "outputId": "c0e73de0-2246-4970-ae4a-bef81eb565fd"
      },
      "source": [
        "best_result = max(results, key=lambda x: x['score'])\n",
        "\n",
        "print(\"Best Isolation Forest Parameters:\")\n",
        "for key, value in best_result.items():\n",
        "    print(f\"{key}: {value}\")"
